<div class="gallery-grid--card">
  <div class="card--header-badge"><span class="badge--flag">🇵🇱</span><%= _('Poland') %></div>
  <p class="card--text card--video-title"><%= _("How Access to Information exposed systemic failures in Poland's 2020 elections") %></p>
  <div class="modal-button card-thumbnail" tabindex="0" role="button" aria-label="<%= _('Open video: TICTeC 25: Unveiling the power of transparency') %>">
    <div class="video-thumbnail">
      <div class="youtube-svg"></div>
      <img src="https://img.youtube.com/vi/CtmdWZ4Nx9w/maxresdefault.jpg" loading="lazy" role="presentation" aria-hidden="true">
    </div>
  </div>
  <div class="modal-content modal-hidden" aria-hidden="true">
    <div class="modal-container" role="dialog" aria-modal="true" aria-labelledby="modal-title-6">
      <div class="modal-header">
        <h3 class="modal-title" id="modal-title-6"><%= _('TICTeC 25: Unveiling the power of transparency') %></h3>
        <button class="modal-close modal-close--just-icon" aria-label="<%= _('Close') %>">×</button>
      </div>
      <p><%= _("How Access to Information exposed systemic failures in Poland's 2020 elections.") %></p>
      <div class="modal-body">
        <div class="video-container">
          <iframe tabindex="0" width="560" height="315" src="https://www.youtube.com/embed/CtmdWZ4Nx9w?enablejsapi=1" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </div>
</div>
