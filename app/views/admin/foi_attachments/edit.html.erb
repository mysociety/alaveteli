<%= render partial: 'intro', locals: {
  info_request: @info_request,
  incoming_message: @incoming_message,
  foi_attachment: @foi_attachment
} %>

<table class="table table-striped table-condensed">
  <tbody>
    <% @foi_attachment.for_admin_column do |name, value| %>
      <tr>
        <td>
          <b><%= name.humanize %></b>
        </td>
        <td>
          <%= admin_value(value) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= form_for [:admin, @foi_attachment], class: 'form form-inline' do |f| %>
  <fieldset class="form-horizontal">
    <legend>Prominence</legend>

    <div class="control-group">
      <%= f.label :prominence, class: 'control-label' %>

      <div class="controls">
        <%= f.select :prominence, FoiAttachment.prominence_states %>
      </div>
    </div>

    <div class="control-group">
      <%= f.label :prominence_reason, 'Reason for prominence', class: 'control-label' %>

      <div class="controls">
        <%= f.text_area :prominence_reason, rows: 5, class: 'span6' %>
      </div>
    </div>
  </fieldset>

  <fieldset class="form-horizontal">
    <legend>Replacement</legend>

      <div class="controls">
        <div class="help-block">
          <p>
            A replacement attachment can be uploaded to provide an alternative
            version that appears to users of the site. Once a replacement is
            added, the original will only be available to admins. This may be
            used to upload a version that fixes formatting errors, or apply
            redactions that are difficult to do via censor rules, for example.
          </p>

          <p>
            <strong>Uploading a replacement will automatically enable locking
            </strong> for this attachment.
          </p>
        </div>
      </div>

      <div class="control-group">
        <%= f.label :replacement_file, class: 'control-label' %>

        <div class="controls">
          <%= f.file_field :replacement_file %>
        </div>
      </div>

      <% if @foi_attachment.main_body_part? %>
        <div class="control-group">
          <%= f.label :replacement_body, class: 'control-label' %>

          <div class="controls">
            <%= f.text_area :replacement_body, rows: 20, class: 'span9' %>
          </div>
        </div>
      <% else %>
        <div class="control-group">
          <%= f.label :replaced_filename, class: 'control-label' %>

          <div class="controls">
            <%= f.text_field :replaced_filename %>
          </div>
        </div>
      <% end %>

      <div class="control-group">
        <%= f.label :replaced_reason, class: 'control-label' %>

        <div class="controls">
          <%= f.text_field :replaced_reason %>
          <span class="help-inline">
            Private reason why attachment as been replaced, such as GDPR case reference
          </span>
        </div>
      </div>
  </fieldset>

  <div class="form-actions">
    <%= f.submit 'Save', class: 'btn btn-success' %>
  </div>
<% end %>

  <fieldset class="form-horizontal">
    <legend>Locking</legend>

    <div class="controls">
      <div class="help-block">
        <p>
          Attachments can be “<%= icon(:lock) %> locked” to prevent further
          modification of their contents, either from automated parsing of the
          underlying data or admin actions like applying/removing redactions.
        </p>

        <strong>When locking an attachment:</strong>

        <ol>
          <li>Attachment will be preserved with current applicable censor rules applied</li>
          <li>New censor rules will not be applied</li>
        </ol>

        <strong>When unlocking an attachment:</strong>
        <ol>
          <li>All applicable censor rules at the point of unlocking will be re-applied to the original attachment</li>
          <li>Any replacement will be removed and the attachment will revert back to the original copy</li>
        </ol>
      </div>
    </div>

    <div class="control-group">
      <div class="controls">
        <% if @foi_attachment.locked? %>
          <%= form_with url: admin_foi_attachment_lock_path(@foi_attachment), scope: :foi_attachment, method: :delete, class: 'span4' do |f| %>
            <div class="input-append">
              <%= f.text_field :lock_reason,
                               placeholder: 'Reason for unlocking',
                               required: true %>

              <%= f.submit 'Unlock', class: 'btn btn-warning' %>
            </div>
          <% end %>
        <% else %>
          <%= form_with url: admin_foi_attachment_lock_path(@foi_attachment), scope: :foi_attachment, class: 'span4' do |f| %>
            <div class="input-append">
              <%= f.text_field :lock_reason,
                               placeholder: 'Reason for locking',
                               required: true %>

              <%= f.submit 'Lock', class: 'btn btn-warning' %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </fieldset>

<% if @foi_attachment.main_body_part? %>
  <hr />
  <h2>Unmasked message body (quotes unfolded):</h2>

  <blockquote>
    <div class="well well-small">
      <%= simple_format(@foi_attachment.unmasked_body) %>
    </div>
  </blockquote>
<% end %>
