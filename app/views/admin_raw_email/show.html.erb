<%= render partial: 'admin_raw_email/intro', locals: { raw_email: @raw_email } %>

<% if @holding_pen %>
  <%= render partial: 'admin_raw_email/holding_pen' %>

  <div>
    <%= render partial: 'admin_incoming_message/holding_pen_actions',
               locals: { incoming_message: @raw_email.incoming_message } %>
  </div>
<% end %>


<% if @raw_email.erased? %>
  <p>
    <%= link_to 'Download', '', class: 'btn', disabled: true %>
    <span class="muted">Erased raw emails cannot be downloaded.</span>
  </p>
<% else %>
  <p>
    <%= link_to 'Download', admin_raw_email_path(@raw_email, format: 'eml'), class: 'btn' %>
    <span class="muted">Download the email for an exact rendering.</span>
  </p>
<% end %>

<table class="table table-striped table-condensed table-hover">
  <thead>
    <tr>
      <th colspan=2>
        Parsed Headers:
      </th>
    </tr>
  </thead>
  <tr>
    <td><strong>From:</strong></td>
    <td><%= address_list(@raw_email.mail.from) %></td>
  </tr>
  <tr>
    <td><strong>SMTP Envelope-From:</strong></td>
    <td><%= address_list(@raw_email.mail.smtp_envelope_from) %></td>
  </tr>
  <tr>
    <td><strong>Envelope-From:</strong></td>
    <td><%= address_list(@raw_email.mail.envelope_from) %></td>
  </tr>
  <tr>
    <td><strong>To:</strong></td>
    <td><%= address_list(@raw_email.mail.to) %></td>
  </tr>
  <tr>
    <td><strong>Envelope-To:</strong></td>
    <td><%= address_list(@raw_email.mail.smtp_envelope_to) %></td>
  </tr>
  <tr>
    <td><strong>Cc:</strong></td>
    <td><%= address_list(@raw_email.mail.cc) %></td>
  </tr>
  <tr>
    <td><strong>Bcc:</strong></td>
    <td><%= address_list(@raw_email.mail.bcc) %></td>
  </tr>
  <tr>
    <td><strong>Subject:</strong></td>
    <td><%= @raw_email.mail.subject %></td>
  </tr>
</table>

<% if @raw_email.erased? %>
  <div class="row">
    <div class="span12">
      <div class="alert alert-warning">
        <p>Cannot show the raw email data as this raw email has been erased.</p>
      </div>
    </div>
  </div>
<% else %>
  <pre><%= h(@raw_email.data_as_text).gsub(/\n/, '<br>').html_safe %></pre>

  <% if feature_enabled?(:raw_email_erase) && !@holding_pen %>
  <div class="row">
    <div class="span12 danger-zone">
      <h1 class="span12 danger-zone__header">Danger Zone</h1>

      <div class="danger-zone__item">
        <div class="span7">
          <p>
            <strong>Erase this Raw Email</strong>
          </p>

          <details>
            <summary>
              Destroy the underlying data from this response.
            </summary>

            <br />

            <p>
              This can be used to <strong>permanently destroy data</strong>
              received in a response by a public body.
            </p>

            <p>
              <ul>
                <li>Destroys the underlying file representation of the response email received</li>
                <li>Locks all attachments that were extracted from this response</li>
              </ul>
            </p>

            <p>
              Note that <strong>this will not erase from any backups</strong>
              or file storage retention policies created outside of Alaveteli.
              In most cases allowing the backed up file to be rotated out is
              fine, but in the most extreme cases you may wish to manually purge
              the file from backups.
            </p>
          </details>

          <br/>
        </div>

        <%= form_with url: admin_raw_email_erasure_path(@raw_email), scope: :raw_email, class: 'span4' do |f| %>
          <div class="input-append">
            <%= f.text_field :erasure_reason,
                             placeholder: 'Reason for erasure',
                             required: true %>

            <%= f.submit 'Erase',
                         class: 'btn btn-danger',
                         data: { confirm: 'Are you sure? This is irreversible.' } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <% end %>
<% end %>
